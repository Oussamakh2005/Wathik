# OCR API Key - Required for extracting text from invoice images
# Get for free from: https://ocr.space/ocrapi
OCR_API_KEY=your-ocr-space-api-key-here

# Database URL - PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/wathik

# Gemini API Key - Required for structuring OCR text into invoice data
# Get from Google AI Studio: https://aistudio.google.com/apikey
# Uses Gemma 4 31B IT model for invoice processing
GEMINI_API_KEY=your-gemini-api-key-here
