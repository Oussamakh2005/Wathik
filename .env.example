# Server config
# PORT the API listens on inside the container (host port comes from API_PORT in docker-compose)
PORT=3000
# Public URL the docs / OpenAPI spec advertise. Set this when hosting (e.g. https://api.example.com).
PUBLIC_API_URL=http://localhost:3000
# Host port to expose the container on (docker-compose only)
API_PORT=3000

# OCR API Key - Required for extracting text from invoice images
# Get for free from: https://ocr.space/ocrapi
OCR_API_KEY=your-ocr-space-api-key-here

# Database URL - PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/wathik

# OpenRouter API Key - Required for structuring OCR text into invoice data
# Get from OpenRouter: https://openrouter.ai/keys
GROQ_API_KEY=your-openrouter-api-key-here
GROQ_MODEL=z-ai/glm-4.5-air:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=60000
